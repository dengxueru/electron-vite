{
  "name": "electron-tsx-vite",
  "private": true,
  "version": "0.0.1",
  "type": "commonjs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/validate.js && node scripts/del.js ./marswrapper.node && node scripts/copy-proto.js && node scripts/copy-rcaddon.js && vite",
    "preview": "vite preview",
    "postinstall": "node ./node_modules/electron/install.js && electron-builder install-app-deps",
    "build": "node scripts/validate.js && node scripts/del.js ./marswrapper.node && node scripts/copy-proto.js && node scripts/copy-rcaddon.js && vite build --mode production && electron-builder --config electron-builder.config.ts",
    "generate-icon": "electron-icon-builder --input ./build/icons/1024x1024.png --output=./build"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@rollup/plugin-commonjs": "^28.0.6",
    "base64-arraybuffer": "^1.0.2",
    "cpy-cli": "^6.0.0",
    "del-cli": "^7.0.0",
    "detectrtc": "^1.4.1",
    "file-system": "^2.2.2",
    "long": "^5.3.2",
    "md5-file": "^5.0.0",
    "shelljs": "^0.10.0",
    "vite-plugin-vue2": "^2.0.3",
    "vue": "2.7.0",
    "vue-property-decorator": "^9.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "electron": "^35.3.0",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.6.2",
    "typescript": "~5.8.3",
    "vite": "^4.5.14",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-template-compiler": "2.7.0",
    "vue-tsc": "^2.2.8"
  }
}
